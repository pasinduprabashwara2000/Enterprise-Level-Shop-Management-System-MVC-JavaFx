		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Database Adapter"/>
		<query language="SQL"><![CDATA[SELECT Customer.name, Payment.amount, Payment.method, Payment.reference, Payment.received_at
FROM Payment
JOIN Customer ON Payment.customer_id = Customer.customerID]]></query>
		<field name="name" class="java.lang.String"/>
		<field name="amount" class="java.math.BigDecimal"/>
		<field name="method" class="java.lang.String"/>
		<field name="reference" class="java.lang.String"/>
		<field name="received_at" class="java.sql.Date"/>
	</dataset>

	<parameter name="FROM_DATE" class="java.util.Date"/>
	<parameter name="TO_DATE" class="java.util.Date"/>

	<query language="SQL"><![CDATA[SELECT Customer.name, Payment.amount, Payment.method, Payment.reference, Payment.received_at
FROM Payment
JOIN Customer ON Payment.customer_id = Customer.customerID
WHERE received_at BETWEEN $P{FROM_DATE} AND $P{TO_DATE}]]></query>

