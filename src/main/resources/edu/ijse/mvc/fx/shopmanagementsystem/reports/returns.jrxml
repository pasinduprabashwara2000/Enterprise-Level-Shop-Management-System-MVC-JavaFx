	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Database Adapter"/>

	<parameter name="FROM_DATE" class="java.util.Date"/>
	<parameter name="TO_DATE" class="java.util.Date"/>

	<query language="SQL"><![CDATA[SELECT Returns.returnId, Customer.name, Returns.returnDate, Returns.action, Returns.status, Returns.reason, Returns.refundAmount
FROM Returns
JOIN Payment ON Returns.paymentId = Payment.payment_id
JOIN Customer ON Payment.customer_id = Customer.customerId
WHERE Returns.returnDate BETWEEN $P{FROM_DATE} AND $P{TO_DATE}]]></query>

